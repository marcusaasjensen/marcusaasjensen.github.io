    <entry xml:lang="en">
        <title>Theme Config Guide</title>
        <published>2022-10-20T00:00:00+00:00</published>
        <updated>2022-10-20T00:00:00+00:00</updated>
        
        <author>
          <name>
            
              Marcus Aas Jensen
            
          </name>
        </author>
        
        <link rel="alternate" type="text/html" href="https://marcusaasjensen.com/theme-config/"/>
        <id>https://marcusaasjensen.com/theme-config/</id>
        
        <content type="html" xml:base="https://marcusaasjensen.com/theme-config/">&lt;p&gt;You can customize Kita theme by editing &lt;code&gt;config.toml&lt;&#x2F;code&gt;.&lt;&#x2F;p&gt;
&lt;p&gt;Here are all the kita theme options:&lt;&#x2F;p&gt;
&lt;pre data-lang=&quot;toml&quot; style=&quot;background-color:#2b303b;color:#c0c5ce;&quot; class=&quot;language-toml &quot;&gt;&lt;code class=&quot;language-toml&quot; data-lang=&quot;toml&quot;&gt;&lt;span style=&quot;color:#65737e;&quot;&gt;# The Kita theme style config.
&lt;&#x2F;span&gt;&lt;span&gt;[extra]
&lt;&#x2F;span&gt;&lt;span style=&quot;color:#65737e;&quot;&gt;# Enable KaTex math formula support globally.
&lt;&#x2F;span&gt;&lt;span style=&quot;color:#bf616a;&quot;&gt;math &lt;&#x2F;span&gt;&lt;span&gt;= &lt;&#x2F;span&gt;&lt;span style=&quot;color:#d08770;&quot;&gt;true
&lt;&#x2F;span&gt;&lt;span style=&quot;color:#65737e;&quot;&gt;# Enable mermaid support globally.
&lt;&#x2F;span&gt;&lt;span style=&quot;color:#bf616a;&quot;&gt;mermaid &lt;&#x2F;span&gt;&lt;span&gt;= &lt;&#x2F;span&gt;&lt;span style=&quot;color:#d08770;&quot;&gt;true
&lt;&#x2F;span&gt;&lt;span style=&quot;color:#65737e;&quot;&gt;# Enable comment support globally.
